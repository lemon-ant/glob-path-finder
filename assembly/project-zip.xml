<assembly xmlns="http://maven.apache.org/ASSEMBLY/3.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/3.0.0 http://maven.apache.org/xsd/assembly-3.0.0.xsd">
    <id>sources</id>
    <formats>
        <format>zip</format> <!-- Archive format: ZIP -->
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory> <!-- Include the project root directory in the ZIP -->
    <fileSets>
        <!-- Include source code (src/) -->
        <fileSet>
            <directory>${project.basedir}/src</directory>
            <outputDirectory>/src</outputDirectory>
            <includes>
                <include>**/*</include> <!-- Everything inside src/ -->
            </includes>
        </fileSet>
        <!-- Include project config files (pom.xml, README, etc.) -->
        <fileSet>
            <directory>${project.basedir}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>pom.xml</include>
                <include>README.md</include> <!-- Add other files if needed, e.g. *.properties -->
            </includes>
            <excludes>
                <exclude>**/target/**</exclude> <!-- Exclude target/ and compiled output -->
                <exclude>.idea/**</exclude> <!-- Exclude IDE files -->
                <exclude>.git/**</exclude> <!-- Exclude Git metadata -->
                <exclude>**/*.class</exclude> <!-- Exclude stray .class files -->
                <exclude>**/build/**</exclude> <!-- Other build artifacts -->
            </excludes>
        </fileSet>
    </fileSets>
</assembly>
